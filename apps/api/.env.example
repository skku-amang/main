# Database (required)
# Port 5433: docker-compose maps host 5433 → container 5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/amang_db

# JWT secrets (required)
ACCESS_TOKEN_SECRET=dev-access-token-secret
REFRESH_TOKEN_SECRET=dev-refresh-token-secret

# Token expiration in seconds
ACCESS_TOKEN_EXPIRES_IN_SECONDS=3600
REFRESH_TOKEN_EXPIRES_IN_SECONDS=604800

# Object storage / MinIO (required)
S3_BUCKET=amang
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000
# S3_REGION=ap-northeast-2  # default: ap-northeast-2

# Server port (default: 8000)
# PORT=8000
