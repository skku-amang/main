# NextAuth.js secret (required)
AUTH_SECRET=dev-auth-secret

# Backend API URL (default: http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend site URL for SEO (default: https://amang.json-server.win)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry DSN (error tracking, disabled in development by default)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
