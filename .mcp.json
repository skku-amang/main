{
  "mcpServers": {
    "amang-notion": {
      "command": "direnv",
      "args": ["exec", ".", "notion-mcp-server"]
    },
    "amang-slack": {
      "command": "direnv",
      "args": ["exec", ".", "mcp-server-slack"],
      "env": {
        "SLACK_TEAM_ID": "T07LTTU4WSZ"
      }
    },
    "amang-kubernetes": {
      "command": "direnv",
      "args": ["exec", ".", "mcp-server-kubernetes"]
    },
    "amang-postgres": {
      "command": "direnv",
      "args": ["exec", ".", "sh", "-c", "mcp-server-postgres $DATABASE_URL"]
    },
    "amang-sentry": {
      "command": "direnv",
      "args": ["exec", ".", "sentry-mcp"]
    },
    "amang-figma": {
      "command": "direnv",
      "args": ["exec", ".", "amang-figma-mcp", "--stdio"]
    }
  }
}